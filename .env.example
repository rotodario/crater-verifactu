# ─── VERI*FACTU ──────────────────────────────────────────────────────────────
# Operating mode: off | shadow | stub | aeat_sandbox | aeat_production
# Start with "stub" for local development. Never enable aeat_production
# without a valid certificate and explicit confirmation.
VERIFACTU_MODE=stub
VERIFACTU_SUBMISSION_ENABLED=false

# Set to true ONLY if your workflow guarantees invoices are final before sending.
# When true, clicking "Send" immediately locks the invoice and queues it to AEAT.
VERIFACTU_ISSUE_ON_SEND=false

# Software identification (required for AEAT registration)
VERIFACTU_SOFTWARE_NAME="Crater VERI*FACTU"
VERIFACTU_SOFTWARE_VERSION=1.0.0
VERIFACTU_SOFTWARE_ID=CRATER-VF-01
VERIFACTU_INSTALLATION_NUMBER=1

# Vendor/developer identification
VERIFACTU_VENDOR_NAME=
VERIFACTU_VENDOR_TAX_ID=

# AEAT certificate (upload via UI is preferred; these are the fallback env vars)
VERIFACTU_CERT_PATH=
VERIFACTU_CERT_PASSWORD=

# AEAT endpoints (defaults are correct — only override if AEAT changes them)
# Persona física / representante:
VERIFACTU_AEAT_SANDBOX_URL=https://prewww1.aeat.es/wlpl/TIKE-CONT/ws/SistemaFacturacion/VerifactuSOAP
VERIFACTU_AEAT_PRODUCTION_URL=https://www1.agenciatributaria.gob.es/wlpl/TIKE-CONT/ws/SistemaFacturacion/VerifactuSOAP
# Certificado de sello:
VERIFACTU_AEAT_SANDBOX_URL_SELLO=https://prewww10.aeat.es/wlpl/TIKE-CONT/ws/SistemaFacturacion/VerifactuSOAP
VERIFACTU_AEAT_PRODUCTION_URL_SELLO=https://www10.agenciatributaria.gob.es/wlpl/TIKE-CONT/ws/SistemaFacturacion/VerifactuSOAP
# Sandbox uses a self-signed CA — keep false unless you add it to your trust store
VERIFACTU_AEAT_SANDBOX_VERIFY_SSL=false
